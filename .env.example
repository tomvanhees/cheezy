# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your apps → SDK setup and configuration

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In — Web client ID from google-services.json (oauth_client type 3)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
